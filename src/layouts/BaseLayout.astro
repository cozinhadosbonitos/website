---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const {
  title,
  description = 'Cooking website Cozinha dos Bonitos',
} = Astro.props
const siteTitle = 'Cozinha dos Bonitos'
const fullTitle = title === 'Home' ? siteTitle : `${title} | ${siteTitle}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@browniebroke" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{fullTitle}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-white text-gray-900">
    <header class="flex justify-center py-10">
      <a href="/" class="text-primary hover:text-primary-dark transition-colors">
        <img src="/logo.svg" alt={siteTitle} class="h-13 w-auto" />
      </a>
    </header>

    <nav class="border-y border-gray-300">
      <div class="mx-auto flex max-w-4xl items-center justify-around px-4 py-3 text-sm font-medium tracking-wide uppercase">
        <a href="/" class="text-gray-600 hover:text-primary-dark transition-colors">All Recipes</a>
        <a href="/" class="text-gray-600 hover:text-primary-dark transition-colors">Sweet</a>
        <a href="/" class="text-gray-600 hover:text-primary-dark transition-colors">Savoury</a>
      </div>
    </nav>

    <main class="flex-1 py-10">
      <slot />
    </main>

    <footer class="bg-primary py-8 text-black">
      <div class="mx-auto max-w-4xl px-4">
        &copy; {new Date().getFullYear()}, Built with
        <a
          href="https://astro.build"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:no-underline"
        >
          Astro
        </a>
      </div>
    </footer>
  </body>
</html>
