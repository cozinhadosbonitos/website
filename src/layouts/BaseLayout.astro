---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Cooking website Cozinha dos Bonitos' } =
  Astro.props
const siteTitle = 'Cozinha dos Bonitos'
const fullTitle = title === 'Home' ? siteTitle : `${title} | ${siteTitle}`

const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="@browniebroke" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{fullTitle}</title>
  </head>
  <body class="flex min-h-screen flex-col bg-warm-bg text-gray-900">
    <header class="relative overflow-hidden bg-warm-bg-alt">
      <div
        class="absolute inset-0 opacity-[0.03]"
        style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22><text x=%2215%22 y=%2240%22 font-size=%2230%22>🍳</text></svg>'); background-size: 60px 60px;"
      >
      </div>
      <div class="relative flex justify-center py-8">
        <a
          href="/"
          class="group flex flex-col items-center gap-2 transition-transform duration-300 hover:scale-105"
        >
          <img
            src="/logo.svg"
            alt={siteTitle}
            class="h-13 w-auto fill-current"
          />
          <span class="text-sm tracking-widest text-primary-dark/60 uppercase">
            Homemade with love
          </span>
        </a>
      </div>
    </header>

    <nav
      class="sticky top-0 z-50 border-b border-primary/10 bg-white/90 backdrop-blur-md"
    >
      <div
        class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3"
      >
        <div class="hidden gap-8 sm:flex">
          <a
            href="/"
            class:list={[
              'relative px-1 py-0.5 text-sm font-semibold tracking-wide uppercase transition-colors duration-200',
              currentPath === '/'
                ? 'text-primary-dark after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:rounded-full after:bg-primary'
                : 'text-gray-500 hover:text-primary-dark',
            ]}
          >
            Home
          </a>
          <a
            href="/recipes/"
            class:list={[
              'relative px-1 py-0.5 text-sm font-semibold tracking-wide uppercase transition-colors duration-200',
              currentPath.startsWith('/recipes')
                ? 'text-primary-dark after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-full after:rounded-full after:bg-primary'
                : 'text-gray-500 hover:text-primary-dark',
            ]}
          >
            Recipes
          </a>
        </div>
        <button
          id="mobile-menu-btn"
          class="text-gray-600 hover:text-primary-dark sm:hidden"
          aria-label="Toggle menu"
        >
          <svg
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </button>
      </div>
      <div id="mobile-menu" class="hidden border-t border-primary/10 sm:hidden">
        <div class="flex flex-col gap-2 px-4 py-3">
          <a
            href="/"
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-semibold transition-colors',
              currentPath === '/'
                ? 'bg-primary-light text-primary-dark'
                : 'text-gray-600 hover:bg-primary-light/50 hover:text-primary-dark',
            ]}
          >
            Home
          </a>
          <a
            href="/recipes/"
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-semibold transition-colors',
              currentPath.startsWith('/recipes')
                ? 'bg-primary-light text-primary-dark'
                : 'text-gray-600 hover:bg-primary-light/50 hover:text-primary-dark',
            ]}
          >
            Recipes
          </a>
        </div>
      </div>
    </nav>
    <script>
      import '../lib/mobile-menu.js'
    </script>

    <main class="flex-1 py-10">
      <slot />
    </main>

    <footer class="relative overflow-hidden bg-gray-900 py-12 text-gray-300">
      <div
        class="absolute inset-0 opacity-5"
        style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2280%22 height=%2280%22 viewBox=%220 0 80 80%22><text x=%2220%22 y=%2255%22 font-size=%2240%22>🍽️</text></svg>'); background-size: 80px 80px;"
      >
      </div>
      <div class="relative mx-auto max-w-5xl px-4">
        <div class="flex flex-col items-center gap-4">
          <img
            src="/logo.svg"
            alt={siteTitle}
            class="h-8 w-auto opacity-40 brightness-200 invert"
          />
          <p class="text-sm text-gray-500">
            Made with love &amp; a pinch of salt
          </p>
          <p class="text-xs text-gray-600">
            &copy; {new Date().getFullYear()}, Built with
            <a
              href="https://astro.build"
              target="_blank"
              rel="noopener noreferrer"
              class="underline transition-colors hover:text-primary"
            >
              Astro
            </a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>
