---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllRecipes, urlFor } from '../lib/sanity'

const allRecipes = await getAllRecipes()
const featured = allRecipes.slice(0, 3)
---

<BaseLayout title="Home">
  <div class="mx-auto max-w-4xl px-4">
    <section class="mb-12 text-center">
      <h2 class="mb-2 text-4xl">Welcome</h2>
      <p class="mx-auto max-w-xl text-gray-600">
        A collection of our favourite recipes, from sweet treats to savoury
        delights.
      </p>
    </section>

    <section>
      <div class="mb-8 flex items-center justify-between">
        <h2 class="text-2xl">Featured Recipes</h2>
        <a
          href="/recipes/"
          class="text-sm font-medium text-primary-dark transition-colors hover:underline"
        >
          View all &rarr;
        </a>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((recipe) => (
            <a
              href={`/recipes/${encodeURIComponent(recipe.title)}/`}
              class="group overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-xl"
            >
              {recipe.photo && (
                <div class="overflow-hidden">
                  <img
                    src={urlFor(recipe.photo).width(400).height(300).url()}
                    alt={recipe.title}
                    width="400"
                    height="300"
                    loading="lazy"
                    class="h-52 w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="p-5">
                <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary-dark">
                  {recipe.title}
                </h3>
                {recipe.tags && recipe.tags.length > 0 && (
                  <div class="mt-2 flex flex-wrap gap-1.5">
                    {recipe.tags.map((tag) => (
                      <span class="rounded-full bg-primary/15 px-2.5 py-0.5 text-xs font-medium text-primary-dark">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
