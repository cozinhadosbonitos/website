---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllRecipes, urlFor } from '../lib/sanity'

const allRecipes = await getAllRecipes()
const featured = allRecipes.slice(0, 3)
---

<BaseLayout title="Home">
  <div class="mx-auto max-w-5xl px-4">
    <!-- Hero Section -->
    <section class="mb-16 py-8 text-center">
      <div class="animate-fade-in-up">
        <span class="mb-4 inline-block text-5xl animate-float">👨‍🍳</span>
        <h1 class="mb-4 text-5xl font-bold tracking-tight md:text-6xl">
          Welcome to our
          <span
            class="bg-gradient-to-r from-primary-dark via-primary to-accent bg-clip-text text-transparent"
          >
            Kitchen
          </span>
        </h1>
      </div>
      <p
        class="animate-fade-in-up-delay-1 mx-auto max-w-lg text-lg leading-relaxed text-gray-500"
      >
        A collection of our favourite recipes, from sweet treats to savoury
        delights. Cooked with love, shared with joy.
      </p>
      <div class="animate-fade-in-up-delay-2 mt-8">
        <a
          href="/recipes/"
          class="group inline-flex items-center gap-2 rounded-full bg-primary px-8 py-3.5 font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-xl hover:shadow-primary-dark/25"
        >
          Explore recipes
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-1"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
          </svg>
        </a>
      </div>
    </section>

    <!-- Featured Recipes -->
    <section>
      <div class="mb-10 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class="text-2xl">✨</span>
          <h2 class="text-3xl font-bold">Featured Recipes</h2>
        </div>
        <a
          href="/recipes/"
          class="group flex items-center gap-1.5 text-sm font-semibold text-primary-dark transition-colors hover:text-accent"
        >
          View all
          <svg
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2.5"
              d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {
          featured.map((recipe) => (
            <a
              href={`/recipes/${recipe.slug}/`}
              class="recipe-card group relative overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-900/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
            >
              {recipe.photo && (
                <div class="relative overflow-hidden">
                  <img
                    src={urlFor(recipe.photo).width(400).height(300).url()}
                    alt={recipe.title}
                    width="400"
                    height="300"
                    loading="lazy"
                    class="h-56 w-full object-cover transition-transform duration-500 group-hover:scale-110"
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                </div>
              )}
              <div class="p-5">
                <h3 class="text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-dark">
                  {recipe.title}
                </h3>
                {recipe.tags && recipe.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {recipe.tags.map((tag) => (
                      <span class="rounded-full bg-primary-light px-3 py-1 text-xs font-semibold text-primary-dark">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>
