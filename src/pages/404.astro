---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="404: Not found">
  <div
    class="flex min-h-[40vh] flex-col items-center justify-center text-center px-4"
  >
    <span class="mb-6 text-7xl animate-float">🍳</span>
    <h1 class="mb-3 text-5xl font-bold">Oops!</h1>
    <p class="mb-2 text-xl text-gray-500">This recipe got burnt...</p>
    <p class="mb-8 text-gray-400">The page you're looking for doesn't exist.</p>
    <a
      href="/"
      class="group inline-flex items-center gap-2 rounded-full bg-primary px-6 py-3 font-semibold text-white shadow-lg shadow-primary/25 transition-all duration-300 hover:-translate-y-0.5 hover:bg-primary-dark hover:shadow-xl"
    >
      <svg
        class="h-4 w-4 transition-transform group-hover:-translate-x-0.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2.5"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to the kitchen
    </a>
  </div>
</BaseLayout>
