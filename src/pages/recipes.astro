---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllRecipes, urlFor } from '../lib/sanity'

const recipes = await getAllRecipes()

// Pre-compute image URLs and collect filter options
const courseTypeLabels: Record<string, string> = {
  appetizer: 'Appetizer',
  dessert: 'Dessert',
  main: 'Main',
  snack: 'Snack',
  starter: 'Starter',
}

const courseTypeEmoji: Record<string, string> = {
  appetizer: '🥗',
  dessert: '🍰',
  main: '🍲',
  snack: '🍿',
  starter: '🥄',
}

const recipesData = recipes.map((recipe) => ({
  title: recipe.title,
  tags: recipe.tags || [],
  courseType: recipe.courseType || '',
  ingredients:
    recipe.ingredients?.map((i) => i.food?.name).filter(Boolean) || [],
  imageUrl: recipe.photo
    ? urlFor(recipe.photo).width(400).height(300).url()
    : '',
  url: `/recipes/${recipe.slug}/`,
  createdAt: recipe._createdAt,
}))

const allCourseTypes = [
  ...new Set(recipesData.map((r) => r.courseType).filter(Boolean)),
].sort()
const allIngredients = [
  ...new Set(recipesData.flatMap((r) => r.ingredients)),
].sort()
---

<BaseLayout title="All Recipes">
  <div class="mx-auto max-w-5xl px-4">
    <div class="mb-10 text-center">
      <h1 class="mb-3 text-4xl font-bold md:text-5xl">
        All Recipes
        <span class="ml-2 inline-block animate-wiggle">📖</span>
      </h1>
      <p class="text-gray-500">
        Browse through {recipesData.length} delicious recipes
      </p>
    </div>

    <!-- Filter Bar -->
    <div
      class="mb-10 rounded-2xl border border-primary/10 bg-white p-5 shadow-sm"
    >
      <div class="flex flex-col gap-4 sm:flex-row sm:flex-wrap sm:items-end">
        <div class="flex-1 sm:min-w-48">
          <label
            for="search"
            class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gray-400"
          >
            Search
          </label>
          <div class="relative">
            <svg
              class="absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-300"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
            <input
              id="search"
              type="text"
              placeholder="What are you craving?"
              class="w-full rounded-xl border border-gray-200 py-2.5 pl-10 pr-3 text-sm transition-all focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
            />
          </div>
        </div>

        <div class="sm:min-w-40">
          <label
            for="course-type"
            class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gray-400"
          >
            Type
          </label>
          <select
            id="course-type"
            class="w-full rounded-xl border border-gray-200 px-3 py-2.5 text-sm transition-all focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
          >
            <option value="">All types</option>
            {
              allCourseTypes.map((type) => (
                <option value={type}>
                  {courseTypeEmoji[type] || ''} {courseTypeLabels[type] || type}
                </option>
              ))
            }
          </select>
        </div>

        <div class="sm:min-w-48">
          <label
            for="ingredient"
            class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-gray-400"
          >
            Ingredient
          </label>
          <select
            id="ingredient"
            class="w-full rounded-xl border border-gray-200 px-3 py-2.5 text-sm transition-all focus:border-primary focus:ring-2 focus:ring-primary/20 focus:outline-none"
          >
            <option value="">All ingredients</option>
            {
              allIngredients.map((ing) => (
                <option value={ing}>
                  {ing.charAt(0).toUpperCase() + ing.slice(1)}
                </option>
              ))
            }
          </select>
        </div>

        <button
          id="clear-filters"
          class="rounded-xl border border-gray-200 px-5 py-2.5 text-sm font-medium text-gray-500 transition-all hover:border-primary/30 hover:bg-primary-light hover:text-primary-dark"
        >
          Clear
        </button>
      </div>
    </div>

    <p
      id="result-count"
      class="mb-6 text-center text-sm font-medium text-gray-400"
    >
    </p>

    <div id="recipe-grid" class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        recipesData.map((recipe) => (
          <a
            href={recipe.url}
            class="recipe-card group relative overflow-hidden rounded-2xl bg-white shadow-md ring-1 ring-gray-900/5 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl"
            data-title={recipe.title.toLowerCase()}
            data-course-type={recipe.courseType}
            data-ingredients={JSON.stringify(recipe.ingredients)}
          >
            {recipe.imageUrl && (
              <div class="relative overflow-hidden">
                <img
                  src={recipe.imageUrl}
                  alt={recipe.title}
                  width="400"
                  height="300"
                  loading="lazy"
                  class="h-52 w-full object-cover transition-transform duration-500 group-hover:scale-110"
                />
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100" />
                {recipe.courseType && (
                  <span class="absolute right-3 top-3 rounded-full bg-white/90 px-2.5 py-1 text-xs font-semibold text-gray-700 shadow-sm backdrop-blur-sm">
                    {courseTypeEmoji[recipe.courseType] || ''}{' '}
                    {courseTypeLabels[recipe.courseType] || recipe.courseType}
                  </span>
                )}
              </div>
            )}
            <div class="p-5">
              <h3 class="text-lg font-bold text-gray-900 transition-colors group-hover:text-primary-dark">
                {recipe.title}
              </h3>
              {recipe.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-1.5">
                  {recipe.tags.map((tag) => (
                    <span class="rounded-full bg-primary-light px-3 py-1 text-xs font-semibold text-primary-dark">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>

    <p id="no-results" class="hidden py-16 text-center text-lg text-gray-400">
      No recipes match your filters. Try something different!
    </p>
  </div>
</BaseLayout>

<script>
  import '../lib/recipe-filters.js'
</script>
