---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getAllRecipes, urlFor } from '../lib/sanity'

const recipes = await getAllRecipes()

// Pre-compute image URLs and collect filter options
const recipesData = recipes.map((recipe) => ({
  title: recipe.title,
  tags: recipe.tags || [],
  ingredients:
    recipe.ingredients?.map((i) => i.food?.name).filter(Boolean) || [],
  imageUrl: recipe.photo
    ? urlFor(recipe.photo).width(400).height(300).url()
    : '',
  url: `/recipes/${encodeURIComponent(recipe.title)}/`,
  createdAt: recipe._createdAt,
}))

const allTags = [...new Set(recipesData.flatMap((r) => r.tags))].sort()
const allIngredients = [
  ...new Set(recipesData.flatMap((r) => r.ingredients)),
].sort()
---

<BaseLayout title="All Recipes">
  <div class="mx-auto max-w-5xl px-4">
    <h1 class="mb-8 text-center text-4xl">All Recipes</h1>

    <div
      class="mb-8 flex flex-col gap-4 rounded-xl bg-gray-50 p-5 sm:flex-row sm:flex-wrap sm:items-end"
    >
      <div class="flex-1 sm:min-w-48">
        <label
          for="search"
          class="mb-1 block text-xs font-medium uppercase tracking-wide text-gray-500"
        >
          Search
        </label>
        <input
          id="search"
          type="text"
          placeholder="Search recipes..."
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm transition-colors focus:border-primary focus:outline-none"
        />
      </div>

      <div class="sm:min-w-40">
        <label
          for="category"
          class="mb-1 block text-xs font-medium uppercase tracking-wide text-gray-500"
        >
          Category
        </label>
        <select
          id="category"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm transition-colors focus:border-primary focus:outline-none"
        >
          <option value="">All</option>
          {
            allTags.map((tag) => (
              <option value={tag}>
                {tag.charAt(0).toUpperCase() + tag.slice(1)}
              </option>
            ))
          }
        </select>
      </div>

      <div class="sm:min-w-48">
        <label
          for="ingredient"
          class="mb-1 block text-xs font-medium uppercase tracking-wide text-gray-500"
        >
          Ingredient
        </label>
        <select
          id="ingredient"
          class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm transition-colors focus:border-primary focus:outline-none"
        >
          <option value="">All</option>
          {
            allIngredients.map((ing) => (
              <option value={ing}>
                {ing.charAt(0).toUpperCase() + ing.slice(1)}
              </option>
            ))
          }
        </select>
      </div>

      <button
        id="clear-filters"
        class="rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-600 transition-colors hover:bg-gray-200"
      >
        Clear
      </button>
    </div>

    <p id="result-count" class="mb-4 text-sm text-gray-500"></p>

    <div id="recipe-grid" class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        recipesData.map((recipe) => (
          <a
            href={recipe.url}
            class="recipe-card group overflow-hidden rounded-xl bg-white shadow-md transition-shadow hover:shadow-xl"
            data-title={recipe.title.toLowerCase()}
            data-tags={JSON.stringify(recipe.tags)}
            data-ingredients={JSON.stringify(recipe.ingredients)}
          >
            {recipe.imageUrl && (
              <div class="overflow-hidden">
                <img
                  src={recipe.imageUrl}
                  alt={recipe.title}
                  width="400"
                  height="300"
                  loading="lazy"
                  class="h-48 w-full object-cover transition-transform duration-300 group-hover:scale-105"
                />
              </div>
            )}
            <div class="p-4">
              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-primary-dark">
                {recipe.title}
              </h3>
              {recipe.tags.length > 0 && (
                <div class="mt-2 flex flex-wrap gap-1.5">
                  {recipe.tags.map((tag) => (
                    <span class="rounded-full bg-primary/15 px-2.5 py-0.5 text-xs font-medium text-primary-dark">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </a>
        ))
      }
    </div>

    <p id="no-results" class="hidden py-12 text-center text-gray-500">
      No recipes match your filters.
    </p>
  </div>
</BaseLayout>

<script>
  import '../lib/recipe-filters.js'
</script>
