{
  "name": "cozinhadosbonitos",
  "description": "Cooking website Cozinha dos Bonitos",
  "license": "MIT",
  "version": "1.0.0",
  "author": "Bruno Alla <alla.brunoo@gmail.com>",
  "repository": "https://github.com/browniebroke/cozinadosbonitos.git",
  "keywords": [
    "cooking",
    "recipe",
    "astro"
  ],
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --ignore-path .gitignore --write .",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --ignore-path .gitignore --check .",
    "lint:tsc": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/sitemap": "^3.3.0",
    "@fontsource/karla": "^5.2.8",
    "@fontsource/lato": "^5.2.7",
    "@sanity/client": "^7.0.0",
    "@sanity/image-url": "^1.1.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^5.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.0",
    "@eslint/eslintrc": "^3.3.0",
    "@eslint/js": "^9.39.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.0",
    "eslint-plugin-astro": "^1.0.0",
    "eslint-plugin-prettier": "^5.5.0",
    "prettier": "^3.8.0",
    "prettier-plugin-astro": "^0.14.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "renovate": {
    "extends": [
      "github>browniebroke/renovate-configs:js-app"
    ]
  }
}
