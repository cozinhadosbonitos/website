{
  "name": "cozinhadosbonitos",
  "description": "Cooking website Cozinha dos Bonitos",
  "license": "MIT",
  "version": "1.0.0",
  "author": "Bruno Alla <alla.brunoo@gmail.com>",
  "repository": "https://github.com/browniebroke/cozinadosbonitos.git",
  "keywords": [
    "cooking",
    "recipe",
    "astro"
  ],
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format": "prettier --ignore-path .gitignore --write .",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --ignore-path .gitignore --check .",
    "lint:tsc": "astro check"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource/karla": "5.2.8",
    "@fontsource/lato": "5.2.7",
    "@sanity/client": "7.23.0",
    "@sanity/image-url": "2.1.1",
    "@tailwindcss/vite": "4.3.2",
    "astro": "7.0.7",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@eslint/compat": "2.1.0",
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@typescript-eslint/parser": "8.63.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "2.1.1",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "es5",
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "renovate": {
    "extends": [
      "github>browniebroke/renovate-configs:js-app"
    ]
  }
}
